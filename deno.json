{
  "name": "@marianmeres/vanilla",
  "version": "1.3.0",
  "exports": "./src/mod.ts",
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
  "publish": {
    "exclude": [
      "docs/archive-old",
      "tmp",
      ".env.example"
    ]
  },
  "tasks": {
    "test": "deno test",
    "test:watch": "deno test --watch",
    "example:build": "deno run -A jsr:@marianmeres/deno-build --outdir example/dist",
    "example:watch": "deno run -A jsr:@marianmeres/deno-build --outdir example/dist --watch",
    "npm:build": "deno run -A scripts/build-npm.ts",
    "npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish && deno task npm:publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish"
  },
  "imports": {
    "@marianmeres/npmbuild": "jsr:@marianmeres/npmbuild@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4,
    "proseWrap": "preserve"
  }
}
